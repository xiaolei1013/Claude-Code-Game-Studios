tests/fixtures/data_registry/*/

# === Build Output ===
# Anchored to repo root so `tools/build/` (the build-script source dir,
# Sprint 19 S19-M5 scaffold) is NOT excluded — only the export-output
# `/build/` dir at the repo root is.
/build/
/builds/
bin/
!addons/**/bin/
obj/
out/
dist/
*.exe
*.dll
*.so
*.dylib
*.app

