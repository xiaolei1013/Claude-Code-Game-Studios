shader_parameter/enabled = 1.0

; DungeonRunView — full-rect anchored Control (extends Screen) per ADR-0007.
;
; Layout:
;   DungeonRunView (Control, full-rect)
;     HeaderLabel              — localized title; text set in _ready() via tr()
;     StatsPanel (VBoxContainer)
;       TickRow (HBoxContainer)
;         TickPrefixLabel      — "Tick:" static; set once in _ready() via tr()
;         TickLabel            — live value; updated per _on_tick_fired (20 Hz)
;       KillCountRow (HBoxContainer)
;         KillCountPrefixLabel — "Kills:" static; set once in _ready() via tr()
;         KillCountLabel       — live value; updated per _on_tick_fired (20 Hz)
;     RunEndOverlay (PanelContainer) — hidden by default; shown on RUN_ENDED
;       RunEndLabel            — receives tr("run_complete_kill_count_format") % kills
;
; mouse_filter rules (ADR-0008):
;   - Labels: MOUSE_FILTER_PASS (1) — text does not intercept taps
;   - Containers (VBoxContainer, HBoxContainer, PanelContainer): MOUSE_FILTER_PASS (1)
;   - Root Control: MOUSE_FILTER_PASS (1) — display-only screen; no tap interception
;
; No interactive Controls in Sprint 8 VS (display-only screen). If a Continue
; Button is added in a future sprint it MUST call UIFramework.assert_tap_target_min.
;
; No Color() literals. No per-screen Theme. Colors via MainRoot.theme cascade.
; No focus_neighbor_* or FOCUS_ALL — keyboard nav suppressed per ADR-0008.

[node name="DungeonRunView" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 1
script = ExtResource("1_dungeon_run_view")

[node name="BiomeBackground" parent="." instance=ExtResource("3_biome_background")]

