; Sprint 11 S11-S2 — canonical audio bus layout for Lantern Guild.
; Hierarchy + default volumes per design/gdd/audio-system.md §C.1.
;
; Bus order matters in Godot's AudioServer — child buses must come AFTER their
; parent so the send target exists when the child is registered. The flat
; layout below organizes buses by parent-first traversal: Master → Music →
; Music/Ambient → Music/Stinger → SFX → SFX/UI → SFX/Combat → SFX/Reward.
;
; Per audio-system.md §G default volumes (dB relative to 0 = unity gain):
;   Master      0 dB
;   Music     -8 dB
;     Ambient    0 dB (relative)
;     Stinger   +2 dB (relative)
;   SFX       -3 dB
;     UI        -2 dB (relative)
;     Combat     0 dB (relative)
;     Reward    +3 dB (relative)
;
; Pointed at by project.godot [audio] bus_layout setting. AudioRouter resolves
; bus indices via AudioServer.get_bus_index(name) at _ready() time.

[gd_resource type="AudioBusLayout" format=3]

[resource]
bus/0/name = &"Master"
bus/0/solo = false
bus/0/mute = false
bus/0/bypass_fx = false
bus/0/volume_db = 0.0
bus/0/send = &""

bus/1/name = &"Music"
bus/1/solo = false
bus/1/mute = false
bus/1/bypass_fx = false
bus/1/volume_db = -8.0
bus/1/send = &"Master"

bus/2/name = &"Music/Ambient"
bus/2/solo = false
bus/2/mute = false
bus/2/bypass_fx = false
bus/2/volume_db = 0.0
bus/2/send = &"Music"

bus/3/name = &"Music/Stinger"
bus/3/solo = false
bus/3/mute = false
bus/3/bypass_fx = false
bus/3/volume_db = 2.0
bus/3/send = &"Music"

bus/4/name = &"SFX"
bus/4/solo = false
bus/4/mute = false
bus/4/bypass_fx = false
bus/4/volume_db = -3.0
bus/4/send = &"Master"

bus/5/name = &"SFX/UI"
bus/5/solo = false
bus/5/mute = false
bus/5/bypass_fx = false
bus/5/volume_db = -2.0
bus/5/send = &"SFX"

bus/6/name = &"SFX/Combat"
bus/6/solo = false
bus/6/mute = false
bus/6/bypass_fx = false
bus/6/volume_db = 0.0
bus/6/send = &"SFX"

bus/7/name = &"SFX/Reward"
bus/7/solo = false
bus/7/mute = false
bus/7/bypass_fx = false
bus/7/volume_db = 3.0
bus/7/send = &"SFX"
