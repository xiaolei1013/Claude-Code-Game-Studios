[sub_resource type="Resource" id="Floor_FM_F1"]
script = ExtResource("2_fl")
id = "frostmire_f1"
display_name = "Floor 1: The Frozen Reeds"
floor_index = 1
enemy_list = [{"enemy_id": "icebound_pilgrim", "count": 2}, {"enemy_id": "marrow_witch", "count": 1}]
expected_clear_time_seconds = 46
is_boss_floor = false
flavor_text = "The reeds here freeze upright every winter and never quite thaw. Something walks between them, patient."

[sub_resource type="Resource" id="Floor_FM_F2"]
script = ExtResource("2_fl")
id = "frostmire_f2"
display_name = "Floor 2: The Bone Causeway"
floor_index = 2
enemy_list = [{"enemy_id": "frost_revenant", "count": 2}, {"enemy_id": "marrow_witch", "count": 2}]
expected_clear_time_seconds = 62
is_boss_floor = false
flavor_text = "A path of bleached bones laid across the bog. Each one a pilgrim who didn't make it. The path keeps growing."

[sub_resource type="Resource" id="Floor_FM_F3"]
script = ExtResource("2_fl")
id = "frostmire_f3"
display_name = "Floor 3: The Hollow Cairns"
floor_index = 3
enemy_list = [{"enemy_id": "icebound_pilgrim", "count": 3}, {"enemy_id": "frost_revenant", "count": 2}]
expected_clear_time_seconds = 92
is_boss_floor = false
flavor_text = "Cairns of frozen earth. Each one carries a single name etched in ice. Some names the guild's records still hold."

[sub_resource type="Resource" id="Floor_FM_F4"]
script = ExtResource("2_fl")
id = "frostmire_f4"
display_name = "Floor 4: The Colossus Bog"
floor_index = 4
enemy_list = [{"enemy_id": "mire_colossus", "count": 2}, {"enemy_id": "marrow_witch", "count": 1}]
expected_clear_time_seconds = 105
is_boss_floor = false
flavor_text = "Shapes rise from the peat. They are older than the marshland. They have been rising in this spot for centuries."

[sub_resource type="Resource" id="Floor_FM_F5"]
script = ExtResource("2_fl")
id = "frostmire_f5"
display_name = "Floor 5: The Hollow Winter's Heart"
floor_index = 5
enemy_list = [{"enemy_id": "the_hollow_winter", "count": 1}]
expected_clear_time_seconds = 185
is_boss_floor = true
flavor_text = "A clearing where the frost never breaks. Three centuries of midwinter held in a single circle. Today, the guild ends it."

