; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Lantern Guild"
config/description="Cozy fantasy idle-clicker — hero roster, dungeon runs, offline progression."
config/features=PackedStringArray("4.6", "Forward Plus", "GDScript")
config/icon="res://icon.svg"

[autoload]

TickSystem="*res://src/core/tick_system/tick_system.gd"
DataRegistry="*res://src/core/data_registry/data_registry.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation=0

[editor_plugins]

enabled=PackedStringArray("res://addons/gdUnit4/plugin.cfg")

[input]

; Input map lands as MVP screens are authored. Mouse + single-finger touch primary per
; .claude/docs/technical-preferences.md — no keyboard nav, no gamepad, no right-click-exclusive.

[physics]

; 2D physics = Godot Physics 2D (Jolt is 3D-only per technical-preferences.md).
; 3D physics setting below is inert for this project (no 3D content in MVP).
3d/physics_engine="Jolt Physics"

[rendering]

renderer/rendering_method="forward_plus"
rendering_device/driver.windows="d3d12"
textures/canvas_textures/default_texture_filter=0
