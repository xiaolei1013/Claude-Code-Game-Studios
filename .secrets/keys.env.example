# Asset-pipeline API keys — COPY this file to `.secrets/keys.env` and fill in.
#
#   cp .secrets/keys.env.example .secrets/keys.env
#   # then edit .secrets/keys.env with your real keys
#
# `.secrets/keys.env` is gitignored and MUST NEVER be committed.
# The pipeline reads os.environ first, then falls back to this file, so you can
# alternatively export these in your shell or put them in
# `.claude/settings.local.json` (also gitignored) under an "env" block.
#
# Keys are read for length/SET-UNSET checks only — never printed or logged.

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
# Used for: SFX (/v1/sound-generation) + music beds (/v1/music).
# Confirm your plan tier permits commercial game use + redistribution of
# generated audio (see ADR-0022 §Risks).
ELEVENLABS_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
# Used for: image generation (generativelanguage.googleapis.com generateContent).
# Image generation requires a billing-enabled key.
GEMINI_API_KEY=

# Optional overrides (defaults are sensible; leave blank to use them).
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# ELEVENLABS_SFX_OUTPUT_FORMAT=mp3_44100_128    # default. Do NOT set pcm_* — the
#   sound-generation endpoint returns *stereo* headerless PCM that can't be
#   downmixed to the ADR's mono target (Python 3.13+ removed audioop); mp3 carries
#   channel metadata so ffmpeg transcodes it to correct mono 44.1kHz.
# ELEVENLABS_MUSIC_OUTPUT_FORMAT=mp3_44100_128
